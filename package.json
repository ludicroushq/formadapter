{
  "name": "@formadapter/repo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.8"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "overrides": {
    "postcss": "8.5.16"
  },
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "bun run lint && bun run typecheck && bun run build && bun run test:coverage && bun tooling/package-artifacts.ts",
    "clean": "turbo run clean && rm -rf node_modules .turbo coverage",
    "dev": "turbo run dev --filter='./packages/*' --filter=@formadapter/docs",
    "dev:docs": "turbo run dev --filter=@formadapter/docs...",
    "dev:example": "turbo run build --filter=@formadapter/example-kitchen-sink^... && turbo run dev --filter=@formadapter/example-kitchen-sink...",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "preview:publish": "pkg-pr-new publish --comment=update --packageManager=bun './packages/core' './packages/react' './packages/html' './packages/daisyui' './packages/shadcn' './packages/server' './packages/nextjs' './packages/tanstack-start' './packages/orpc' './packages/http'",
    "release": "bun run build && bun tooling/package-artifacts.ts && changeset publish",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo run build --filter='./packages/*' && rm -rf docs/.next-e2e examples/kitchen-sink/.next-e2e && playwright test",
    "test:pack": "turbo run build --filter='./packages/*' && bun tooling/package-artifacts.ts",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck && tsc --project tsconfig.test.json --noEmit",
    "version": "changeset version && bun install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.29.7",
    "@playwright/test": "^1.61.1",
    "@standard-schema/spec": "^1.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "^20.10.6",
    "oxlint": "^1.73.0",
    "pkg-pr-new": "^0.0.75",
    "publint": "^0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsdown": "^0.21.7",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "vitest": "4.1.10"
  }
}
