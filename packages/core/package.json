{
  "name": "@formadapter/core",
  "version": "0.0.1",
  "description": "Framework-free schema compilation and validation primitives for FormAdapter.",
  "keywords": [
    "forms",
    "schema",
    "standard-schema",
    "json-schema",
    "typescript"
  ],
  "homepage": "https://formadapter.com",
  "bugs": {
    "url": "https://github.com/ludicroushq/formadapter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludicroushq/formadapter.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "ludicrous",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "arktype": "^2.2.3",
    "zod": "^4.4.3"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .turbo",
    "dev": "tsdown --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
