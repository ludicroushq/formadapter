{
  "name": "@formadapter/tanstack-start",
  "version": "0.0.1",
  "description": "TanStack Start server-function integration for FormAdapter.",
  "keywords": [
    "forms",
    "server-functions",
    "tanstack-start",
    "typescript"
  ],
  "homepage": "https://formadapter.com",
  "bugs": {
    "url": "https://github.com/ludicroushq/formadapter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludicroushq/formadapter.git",
    "directory": "packages/tanstack-start"
  },
  "license": "MIT",
  "author": "ludicrous",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@formadapter/core": "^0.0.1"
  },
  "peerDependencies": {
    "@tanstack/react-start": ">=1.168.25 <2",
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-start": "1.168.25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .turbo",
    "dev": "tsdown --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
