{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "react",
    "jsx-a11y",
    "import",
    "vitest"
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/.next/**",
    "**/.next-e2e/**",
    "**/.turbo/**",
    "**/dist/**",
    "coverage/**",
    "node_modules/**"
  ]
}
